  "webhooks": [
    {
      "path": "/install_callback",
      "method": "GET",
      "secret_header": ""
    }
  ],
  "lifecycle": {
    "health_check": {
      "interval_sec": 60
    }
  },
  "secrets": [
    {
      "name": "github_app_slug",
      "description": "The GitHub App's URL slug, e.g. 'webbee-imperal' for github.com/apps/webbee-imperal — shown in the App's settings URL on github.com. Public by nature (it's part of a public URL), but declared as a secret for consistency with the rest of the App's identity and to keep it configurable without a code change.",
      "required": true,
      "write_mode": "user",
      "max_bytes": 128,
      "scope": "app"
    },
    {
      "name": "github_app_id",
      "description": "Numeric GitHub App ID, shown at the top of the App's settings page on github.com (Developer settings → GitHub Apps → your app).",
      "required": true,
      "write_mode": "user",
      "max_bytes": 32,
      "scope": "app"
    },
    {
      "name": "github_app_private_key",
      "description": "PEM-encoded private key generated for the GitHub App (Developer settings → GitHub Apps → your app → Private keys → Generate a private key). Used to sign short-lived JWTs that are exchanged for per-installation access tokens — never sent to GitHub directly, never logged, never returned to chat.",
      "required": true,
      "write_mode": "user",
      "max_bytes": 8192,
      "scope": "app"
    },
    {
      "name": "github_webhook_secret",
      "description": "Shared secret configured in the GitHub App's Webhook settings, used to verify that incoming setup-callback requests really come from GitHub (HMAC-SHA256 signature check) before trusting them.",
      "required": false,
      "write_mode": "user",
      "max_bytes": 256,
      "scope": "app"
    }
  ],
